---
/**
 * Schema de ficha técnica — @graph com BreadcrumbList + Product + Vehicle + FAQPage.
 * Gerado do frontmatter da collection `fichas` (Template B do plano de schema).
 */
import { modeloSameAs } from '../../lib/wikis';
import { fotoPorModelo } from '../../lib/fotos';

interface Props {
  data: any;
  url: string;
  breadcrumb: { name: string; item?: string }[];
}
const { data, url, breadcrumb } = Astro.props;
const site = 'https://hachiroku.com.br';
const nome = `${data.marca} ${data.modelo} ${data.ano} ${data.versao}`;
const fichaImagem = `${site}${fotoPorModelo(data.marca, data.modelo, 'ficha')}`;
const _fichaModeloKey = `${data.marca.toLowerCase()}/${data.modelo.toLowerCase().replace(/\s+/g, '-')}`;

// Specs dos grupos k/v do frontmatter → PropertyValue (Vehicle herda additionalProperty de Product)
const specGroups: [string, { k: string; v: string }[]][] = [
  ['Motor', data.motor ?? []],
  ['Transmissão', data.transmissao ?? []],
  ['Desempenho', data.desempenho ?? []],
  ['Consumo', data.consumo ?? []],
  ['Dimensões', data.dimensoes ?? []],
  ['Chassi', data.chassi ?? []],
];
const additionalProperty = specGroups.flatMap(([grupo, specs]) =>
  specs.map((s) => ({
    '@type': 'PropertyValue',
    name: s.k,
    value: s.v,
    propertyID: grupo,
  }))
);

const graph: any[] = [
  {
    '@type': 'BreadcrumbList',
    '@id': `${url}#breadcrumb`,
    itemListElement: breadcrumb.map((b, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: b.name,
      item: b.item ?? (i === breadcrumb.length - 1 ? url : undefined),
    })),
  },
  {
    '@type': 'TechArticle',
    '@id': `${url}#article`,
    headline: data.seoTitle ?? data.title,
    description: data.description,
    proficiencyLevel: 'Expert',
    inLanguage: 'pt-BR',
    about: { '@id': `${url}#vehicle` },
    author: data.autor ? { '@type': 'Person', name: data.autor.nome, url: data.autor.sameAs ?? `${site}/equipe/`, ...(data.autor.credencial ? { jobTitle: data.autor.credencial } : {}), ...(data.autor.sameAs ? { sameAs: data.autor.sameAs } : {}) } : { '@id': `${site}/#organization` },
    publisher: { '@id': `${site}/#organization` },
    datePublished: data.pubDate?.toISOString().slice(0, 10),
    dateModified: (data.updatedDate ?? data.pubDate)?.toISOString().slice(0, 10),
    mainEntityOfPage: { '@type': 'WebPage', '@id': url },
    image: {
      '@type': 'ImageObject',
      url: fichaImagem,
      width: 1200,
      height: 640,
    },
    ...(data.faq?.length ? { hasPart: [{ '@id': `${url}#faq` }] } : {}),
  },
  {
    '@type': 'Vehicle',
    '@id': `${url}#vehicle`,
    name: nome,
    description: data.description,
    image: fichaImagem,
    brand: { '@type': 'Brand', name: data.marca },
    manufacturer: { '@type': 'Organization', name: data.marca },
    model: data.modelo,
    modelDate: String(data.ano),
    vehicleConfiguration: data.versao,
    bodyType: data.carroceria ?? undefined,
    fuelType: data.combustivel,
    ...(additionalProperty.length ? { additionalProperty } : {}),
    ...(data.cilindrada
      ? { vehicleEngine: { '@type': 'EngineSpecification', engineDisplacement: data.cilindrada } }
      : {}),
    ...(modeloSameAs(_fichaModeloKey) ? { sameAs: modeloSameAs(_fichaModeloKey) } : {}),
  },
];

if (data.faq?.length) {
  graph.push({
    '@type': 'FAQPage',
    '@id': `${url}#faq`,
    mainEntity: data.faq.map((f: any, i: number) => ({
      '@type': 'Question',
      '@id': `${url}#faq-${i}`,
      name: f.pergunta,
      acceptedAnswer: { '@type': 'Answer', text: f.resposta },
    })),
  });
}

const jsonld = { '@context': 'https://schema.org', '@graph': graph };
---
<script type="application/ld+json" set:html={JSON.stringify(jsonld)} />

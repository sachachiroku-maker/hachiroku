---
/**
 * Schema de guia de compra — @graph com BreadcrumbList + Article + ItemList (checklist) + FAQPage.
 * Template D do plano de schema. Alvo: AI Overview citável + sitelinks.
 */
interface Props {
  data: any;
  url: string;
  breadcrumb: { name: string; item?: string }[];
}
const { data, url, breadcrumb } = Astro.props;
const site = 'https://hachiroku.com.br';

const graph: any[] = [
  {
    '@type': 'BreadcrumbList',
    '@id': `${url}#breadcrumb`,
    itemListElement: breadcrumb.map((b, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: b.name,
      item: b.item ?? (i === breadcrumb.length - 1 ? url : undefined),
    })),
  },
  {
    '@type': 'Article',
    '@id': `${url}#article`,
    headline: data.title,
    description: data.description,
    datePublished: data.pubDate.toISOString().slice(0, 10),
    dateModified: (data.updatedDate ?? data.pubDate).toISOString().slice(0, 10),
    inLanguage: 'pt-BR',
    author: data.autor ? { '@type': 'Person', name: data.autor.nome, url: data.autor.sameAs ?? `${site}/equipe/`, ...(data.autor.credencial ? { jobTitle: data.autor.credencial } : {}), ...(data.autor.sameAs ? { sameAs: data.autor.sameAs } : {}) } : { '@id': `${site}/#organization` },
    publisher: { '@id': `${site}/#organization` },
    isPartOf: { '@id': `${site}/#website` },
    mainEntityOfPage: { '@type': 'WebPage', '@id': url },
    ...(data.imagem ? { image: { '@type': 'ImageObject', url: `${site}${data.imagem}`, width: 1200, height: 640 } } : {}),
    speakable: { '@type': 'SpeakableSpecification', cssSelector: ['.faq'] },
    hasPart: [
      ...(data.checklist?.length ? [{ '@id': `${url}#checklist` }] : []),
      ...(data.faq?.length ? [{ '@id': `${url}#faq` }] : []),
    ],
  },
];

if (data.checklist?.length) {
  graph.push({
    '@type': 'ItemList',
    '@id': `${url}#checklist`,
    name: 'Checklist de verificação',
    itemListElement: data.checklist.map((c: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: c.item,
    })),
  });
}

if (data.faq?.length) {
  graph.push({
    '@type': 'FAQPage',
    '@id': `${url}#faq`,
    mainEntity: data.faq.map((f: any, i: number) => ({
      '@type': 'Question',
      '@id': `${url}#faq-${i}`,
      name: f.pergunta,
      acceptedAnswer: { '@type': 'Answer', text: f.resposta },
    })),
  });
}

const jsonld = { '@context': 'https://schema.org', '@graph': graph };
---
<script type="application/ld+json" set:html={JSON.stringify(jsonld)} />

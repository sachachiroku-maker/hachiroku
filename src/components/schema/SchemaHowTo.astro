---
/**
 * Schema de tutorial — @graph com BreadcrumbList + HowTo + Article + FAQPage.
 * Template C do plano de schema.
 */
interface Props {
  data: any;
  url: string;
  breadcrumb: { name: string; item?: string }[];
}
const { data, url, breadcrumb } = Astro.props;
const site = 'https://hachiroku.com.br';

const graph: any[] = [
  {
    '@type': 'BreadcrumbList',
    '@id': `${url}#breadcrumb`,
    itemListElement: breadcrumb.map((b, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: b.name,
      item: b.item ?? (i === breadcrumb.length - 1 ? url : undefined),
    })),
  },
  {
    '@type': 'Article',
    '@id': `${url}#article`,
    headline: data.title,
    description: data.description,
    datePublished: data.pubDate?.toISOString().slice(0, 10),
    dateModified: (data.updatedDate ?? data.pubDate)?.toISOString().slice(0, 10),
    inLanguage: 'pt-BR',
    author: data.autor ? { '@type': 'Person', name: data.autor.nome, ...(data.autor.credencial ? { jobTitle: data.autor.credencial } : {}), ...(data.autor.sameAs ? { sameAs: data.autor.sameAs } : {}) } : { '@id': `${site}/#organization` },
    publisher: { '@id': `${site}/#organization` },
    isPartOf: { '@id': `${site}/#website` },
    mainEntityOfPage: { '@type': 'WebPage', '@id': url },
    ...(data.imagem ? { image: { '@type': 'ImageObject', url: `${site}${data.imagem}`, width: 1200, height: 640 } } : {}),
    speakable: { '@type': 'SpeakableSpecification', cssSelector: ['.passos', '.faq'] },
    hasPart: [{ '@id': `${url}#howto` }, ...(data.faq?.length ? [{ '@id': `${url}#faq` }] : [])],
  },
  {
    '@type': 'HowTo',
    '@id': `${url}#howto`,
    name: data.title,
    description: data.description,
    inLanguage: 'pt-BR',
    isPartOf: { '@id': `${url}#article` },
    ...(data.tempo ? { totalTime: data.tempo } : {}),
    ...(data.custoEstimado ? { estimatedCost: data.custoEstimado } : {}),
    ...(data.ferramentas?.length ? { tool: data.ferramentas.map((t: string) => ({ '@type': 'HowToTool', name: t })) } : {}),
    ...(data.materiais?.length ? { supply: data.materiais.map((s: string) => ({ '@type': 'HowToSupply', name: s })) } : {}),
    step: (data.passos ?? []).map((s: any, i: number) => ({
      '@type': 'HowToStep', position: i + 1, name: s.nome, text: s.texto,
    })),
  },
];

if (data.faq?.length) {
  graph.push({
    '@type': 'FAQPage',
    '@id': `${url}#faq`,
    mainEntity: data.faq.map((f: any, i: number) => ({
      '@type': 'Question',
      '@id': `${url}#faq-${i}`,
      name: f.pergunta,
      acceptedAnswer: { '@type': 'Answer', text: f.resposta },
    })),
  });
}

const jsonld = { '@context': 'https://schema.org', '@graph': graph };
---
<script type="application/ld+json" set:html={JSON.stringify(jsonld)} />

---
// Tokens do Design System (ordem importa: fonts → colors → typography → spacing → base)
import '../styles/tokens/fonts.css';
import '../styles/tokens/colors.css';
import '../styles/tokens/typography.css';
import '../styles/tokens/spacing.css';
import '../styles/tokens/base.css';
import '../styles/site.css';
import SchemaSite from '../components/schema/SchemaSite.astro';
import Icon from '../components/ui/Icon.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  type?: 'website' | 'article';
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  pubDate?: Date;
  updatedDate?: Date;
  author?: string;
}
const { title, description, canonical, type = 'website', image, imageAlt, noindex, pubDate, updatedDate, author } = Astro.props;
const site = 'https://hachiroku.com.br';
const canonicalURL = canonical ?? new URL(Astro.url.pathname, site).href;
const ogImage = image
  ? (image.startsWith('http') ? image : `${site}${image}`)
  : `${site}/logos/hachiroku-lockup.png`;
const ogImageType = ogImage.endsWith('.jpg') || ogImage.endsWith('.jpeg') ? 'image/jpeg' : 'image/png';
// Meta description: Google trunca ~155-160 chars. O `description` longo segue como resumo citável no corpo.
const metaDesc = description && description.length > 158
  ? description.slice(0, 155).replace(/\s+\S*$/, '') + '…'
  : description;

// Navegação principal + estado ativo (UI kit)
const path = Astro.url.pathname;
const NAV = [
  ['Problemas', '/problemas/'],
  ['Manutenção', '/manutencao/'],
  ['Guia de compra', '/guia-de-compra/'],
  ['Ficha técnica', '/ficha-tecnica/'],
  ['Elétricos', '/eletricos/'],
  ['Marcas', '/marca/'],
];
const isActive = (href: string) => path === href || path.startsWith(href);
const getAriaCurrent = (href: string) => {
  if (path === href) return 'page';
  if (path.startsWith(href)) return 'true';
  return undefined;
};
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('hk-theme') ||
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {}
      })();
    </script>

    <!-- Google tag (gtag.js) — GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-QM1MYBRVD7" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-QM1MYBRVD7');
    </script>

    <title>{title}</title>
    <meta name="description" content={metaDesc} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="Hachiroku" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Preload das famílias críticas -->
    <link rel="preload" href="/fonts/saira-700-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/saira-800-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/plexsans-400-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/plexmono-400-latin.woff2" as="font" type="font/woff2" crossorigin />

    <link rel="icon" href="/logos/hachiroku-badge-86-red.png" />
    <link rel="apple-touch-icon" href="/logos/hachiroku-badge-86.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="Hachiroku" href="/rss.xml" />
    <meta name="theme-color" content="#161510" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={imageAlt ?? 'Hachiroku — O Seu Mecânico Digital'} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt ?? 'Hachiroku — O Seu Mecânico Digital'} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content={ogImageType} />
    {type === 'article' && pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
    {type === 'article' && (updatedDate ?? pubDate) && <meta property="article:modified_time" content={(updatedDate ?? pubDate)!.toISOString()} />}
    {type === 'article' && author && <meta property="article:author" content={author} />}
    <meta name="twitter:site" content="@hachiroku" />
    <meta name="twitter:creator" content="@hachiroku" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDesc} />
    <SchemaSite />
    <slot name="head" />
  </head>
  <body>
    <a href="#conteudo" class="skip-link">Pular para o conteúdo</a>
    <div class="site-header" data-pagefind-ignore>
      <!-- utility bar: independência editorial (UI kit) -->
      <div class="utility-bar">
        <span class="util-left"><span class="util-dot" aria-hidden="true">●</span> INDEPENDENTE · SEM VERBA DE MONTADORA</span>
        <span class="util-right">
          <span>hachiroku.com.br</span>
          <a href="/busca/">Newsletter de recalls</a>
        </span>
      </div>
      <!-- header principal -->
      <header class="header-main">
        <a href="/" class="brand" aria-label="Hachiroku, página inicial">
          <img class="logo-on-light" src="/logos/hachiroku-lockup.png" alt="Hachiroku" width="150" height="29" />
          <img class="logo-on-dark" src="/logos/hachiroku-lockup-light.png" alt="Hachiroku" width="150" height="29" />
        </a>
        <input type="checkbox" id="nav-toggle" class="nav-toggle-cb sr-only" aria-controls="site-nav" aria-label="Abrir menu de navegação" />
        <label for="nav-toggle" class="nav-burger" aria-hidden="true"><span></span><span></span><span></span></label>
        <nav id="site-nav" aria-label="Navegação principal" class="site-nav">
          {NAV.map(([label, href]) => (
            <a href={href} class={isActive(href) ? 'nav-link active' : 'nav-link'} aria-current={getAriaCurrent(href)}>{label}</a>
          ))}
        </nav>
        <div class="header-tools">
          <form class="header-search" role="search" action="/busca/" method="get">
            <span class="hs-icon" aria-hidden="true"><Icon name="search" size={16} /></span>
            <input type="search" name="q" placeholder="problema + modelo…" aria-label="Buscar no Hachiroku" />
          </form>
          <button class="theme-toggle" type="button" aria-pressed="false" aria-label="Alternar entre tema claro e escuro"
            onclick="(function(b){var d=document.documentElement;var n=d.getAttribute('data-theme')==='dark'?'light':'dark';d.setAttribute('data-theme',n);b.setAttribute('aria-pressed',String(n==='dark'));try{localStorage.setItem('hk-theme',n)}catch(e){}})(this)">
            <span class="t-light" aria-hidden="true">◑</span><span class="t-dark" aria-hidden="true">◐</span>
          </button>
        </div>
      </header>
    </div>

    <main id="conteudo" data-pagefind-body>
      <slot />
    </main>

    <footer class="site-footer" data-theme="dark" data-pagefind-ignore>
      <div class="wrap footer-top">
        <div class="footer-brand-col">
          <img class="footer-logo" src="/logos/hachiroku-lockup-light.png" alt="Hachiroku" width="150" height="29" />
          <p>Soluções automotivas de precisão. Editorial independente, sem verba de montadora.</p>
        </div>
        <nav class="footer-cols" aria-label="Links do rodapé">
          <div>
            <p class="footer-h">Conteúdo</p>
            <a href="/problemas/">Problemas</a>
            <a href="/manutencao/">Manutenção</a>
            <a href="/guia-de-compra/">Guia de compra</a>
            <a href="/ficha-tecnica/">Ficha técnica</a>
            <a href="/eletricos/">Elétricos</a>
          </div>
          <div>
            <p class="footer-h">Por sistema</p>
            <a href="/sistema/motor-e-lubrificacao/">Motor e óleo</a>
            <a href="/sistema/cambio-e-transmissao/">Câmbio</a>
            <a href="/sistema/suspensao/">Suspensão</a>
            <a href="/sistema/freios/">Freios</a>
            <a href="/sistema/eletrica-e-eletronica/">Elétrica</a>
            <a href="/sistema/arrefecimento/">Arrefecimento</a>
          </div>
          <div>
            <p class="footer-h">Por tema</p>
            <a href="/motor/ea211-tsi/">Motor TSI (EA211)</a>
            <a href="/motor/firefly/">Motor Firefly</a>
            <a href="/motor/t270/">Motor 1.3 Turbo T270</a>
            <a href="/tecnologia/correia-banhada-a-oleo/">Correia banhada a óleo</a>
            <a href="/tecnologia/cambio-cvt/">Câmbio CVT</a>
          </div>
          <div>
            <p class="footer-h">Hachiroku</p>
            <a href="/sobre/">Sobre</a>
            <a href="/equipe/">Equipe</a>
            <a href="/politicas/">Políticas e termos</a>
            <a href="/creditos/">Créditos</a>
            <a href="/busca/">Buscar</a>
          </div>
        </nav>
      </div>
      <p class="footer-copy wrap">八六 · AE86 · © 2026 HACHIROKU · O SEU MECÂNICO DIGITAL</p>
    </footer>
  </body>
</html>

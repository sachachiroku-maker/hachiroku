---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiloCta from '../../components/ui/SiloCta.astro';
const itens = (await getCollection('eletricos', ({ data }) => !data.draft)).map((e) => ({ id: e.id, ...e.data }));

const site = 'https://hachiroku.com.br';
const url = `${site}/eletricos/`;
const jsonld = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'BreadcrumbList', '@id': `${url}#breadcrumb`, itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Início', item: `${site}/` },
      { '@type': 'ListItem', position: 2, name: 'Elétricos', item: url },
    ] },
    { '@type': 'CollectionPage', '@id': `${url}#webpage`,
      name: 'Carros Elétricos e Híbridos | Hachiroku',
      description: 'A vertical de carros elétricos do Hachiroku: autonomia real, bateria, wallbox, garantia e diagnóstico de EVs como BYD, GWM e cia.',
      inLanguage: 'pt-BR', isPartOf: { '@id': `${site}/#website` },
      publisher: { '@id': `${site}/#organization` }, breadcrumb: { '@id': `${url}#breadcrumb` } },
  ],
};
---
<BaseLayout title="Carros Elétricos e Híbridos | Hachiroku" description="A vertical de carros elétricos do Hachiroku: autonomia real, bateria, wallbox, garantia e diagnóstico de EVs como BYD, GWM e cia. Profundidade técnica que os portais tradicionais não têm." canonical={url}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />
  <section class="hero" style="padding-block:var(--space-16)">
    <p class="kicker" style="color:var(--asphalt-300)">CARROS ELÉTRICOS E HÍBRIDOS</p>
    <h1>Elétricos</h1>
    <p class="tagline">Autonomia real, sem hype</p>
  </section>
  <section class="silos" aria-label="Conteúdo de elétricos">
    {itens.map((i) => (<a class="silo-card" href={`/eletricos/${i.id}/`}><h2>{i.entidade.marca} {i.entidade.modelo}</h2><p>{i.description}</p></a>))}
  </section>
  <SiloCta />
</BaseLayout>

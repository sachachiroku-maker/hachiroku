---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaGuia from '../../components/schema/SchemaGuia.astro';
import Afiliado from '../../components/ui/Afiliado.astro';
import Toc from '../../components/ui/Toc.astro';
import Photo from '../../components/ui/Photo.astro';
import { fotoPorModelo, fotoPorId } from '../../lib/fotos';

export async function getStaticPaths() {
  const entries = await getCollection('guias', ({ data }) => !data.draft);
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content, headings } = await render(entry);

const site = 'https://hachiroku.com.br';
const url = new URL(`/guia-de-compra/${entry.id}/`, site).href;
const breadcrumb = [
  { name: 'Guia de Compra', item: `${site}/guia-de-compra/` },
  { name: data.title },
];
const fmt = (d) => d.toLocaleDateString('pt-BR');
---
<BaseLayout title={`${data.seoTitle ?? data.title} | Hachiroku`} description={data.description} canonical={url} type="article" image={fotoPorId(entry.id)} pubDate={data.pubDate} updatedDate={data.updatedDate} author={data.autor.nome}>
  <SchemaGuia data={data} url={url} breadcrumb={breadcrumb} />

  <article class="prose">
    <nav class="breadcrumb" aria-label="Você está em">
      <a href="/guia-de-compra/">Guia de Compra</a> · <span>{data.modelo ?? 'Guia'}</span>
    </nav>

    <header>
      <p class="kicker">{data.kicker}</p>
      <h1 class="article-title">{data.h1 ?? data.title}</h1>
      <div class="article-meta">
        <span itemprop="author" itemscope itemtype="https://schema.org/Person"><a href="/equipe/" itemprop="url"><span itemprop="name">{data.autor.nome}</span></a>{data.autor.credencial ? ` · ${data.autor.credencial}` : ''}</span>
        <time datetime={(data.updatedDate ?? data.pubDate).toISOString().slice(0,10)}>Atualizado em {fmt(data.updatedDate ?? data.pubDate)}</time>
      </div>
    </header>

    <p class="lead">{data.veredito}</p>

    <Photo label={(data.marca && data.modelo) ? `${data.marca} ${data.modelo}` : data.title} h={260} src={data.marca && data.modelo ? fotoPorModelo(data.marca, data.modelo, 'guia') : '/img/capas/guia.webp'} class="artigo-capa" priority />

    <Toc headings={headings} />

    <Content />

    {data.checklist.length > 0 && (
      <section aria-label="Checklist de verificação">
        <h2>Checklist: o que verificar antes de fechar negócio</h2>
        <ul class="checklist">
          {data.checklist.map((c) => (
            <li class={c.critico ? 'crit' : ''}>
              <strong>{c.item}</strong>
              <span>{c.detalhe}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    {data.afiliados.length > 0 && (
      <section aria-label="Itens úteis na compra">
        {data.afiliados.map((a) => (<Afiliado produto={a.produto} nota={a.nota} busca={a.busca} programa={a.programa} cta={a.cta} />))}
      </section>
    )}

    {data.faq.length > 0 && (
      <section aria-label="Perguntas frequentes">
        <h2>Perguntas frequentes</h2>
        <dl class="faq">{data.faq.map((f) => (<><dt>{f.pergunta}</dt><dd>{f.resposta}</dd></>))}</dl>
      </section>
    )}

    {data.disclaimer && <p class="disclaimer" role="note">{data.disclaimer}</p>}

    {data.relacionados.length > 0 && (
      <nav class="relacionados" aria-label="Conteúdo relacionado">
        <p class="kicker">CONTINUE A DECISÃO</p>
        <ul>{data.relacionados.map((r) => (<li><a href={r.url}>{r.titulo}</a></li>))}</ul>
      </nav>
    )}
  </article>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiloCta from '../../components/ui/SiloCta.astro';

// Modelos com conteúdo (agrupa pelas folhas existentes)
const entries = await getCollection('problemas', ({ data }) => !data.draft);
const modelos = new Map<string, { marca: string; modelo: string; slug: string; count: number }>();
for (const e of entries) {
  const [marcaSlug, modeloSlug] = e.id.split('/');
  const key = `${marcaSlug}/${modeloSlug}`;
  const cur = modelos.get(key);
  modelos.set(key, { marca: e.data.entidade.marca, modelo: e.data.entidade.modelo, slug: key, count: (cur?.count ?? 0) + 1 });
}
const lista = [...modelos.values()];

const site = 'https://hachiroku.com.br';
const url = `${site}/problemas/`;
const jsonld = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'BreadcrumbList', '@id': `${url}#breadcrumb`, itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Início', item: `${site}/` },
      { '@type': 'ListItem', position: 2, name: 'Diagnóstico por modelo', item: url },
    ] },
    { '@type': 'CollectionPage', '@id': `${url}#webpage`,
      name: 'Meu carro está com problema: diagnóstico por modelo | Hachiroku',
      description: 'Barulho estranho, luz acesa, carro falhando? Diagnóstico direto por modelo: Onix, Polo, HB20, Argo, Creta e mais. Causas reais e custo de reparo.',
      inLanguage: 'pt-BR', isPartOf: { '@id': `${site}/#website` },
      publisher: { '@id': `${site}/#organization` }, breadcrumb: { '@id': `${url}#breadcrumb` } },
  ],
};
---
<BaseLayout
  title="Meu carro está com problema: diagnóstico por modelo | Hachiroku"
  description="Barulho estranho, luz acesa, carro falhando? Diagnóstico direto por modelo: Onix, Polo, HB20, Argo, Creta e mais. Causas reais e custo de reparo."
  canonical={url}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />
  <section class="hero" style="padding-block:var(--space-16)">
    <p class="kicker" style="color:var(--asphalt-300)">DIAGNÓSTICO POR MODELO</p>
    <h1>Meu carro está com problema?</h1>
    <p class="tagline">Escolha o modelo e descubra a causa antes de ir à oficina</p>
  </section>

  <section class="prose" style="max-width:var(--prose-width);margin-inline:auto;padding-block:0 var(--space-8)">
    <p>
      Barulho estranho na dianteira, luz de injeção acesa, consumo de óleo acima do esperado ou câmbio que
      soluça no trânsito. Cada sintoma tem uma causa específica que varia de modelo para modelo, e conhecer
      essa causa antes de chegar à oficina significa negociar melhor, não cair em cobranças desnecessárias
      e tomar a decisão certa sobre fazer ou adiar o reparo. Selecione o seu modelo abaixo para acessar os
      diagnósticos mapeados pela nossa equipe técnica, com a causa real, o custo médio do reparo e o nível
      de urgência para cada defeito crônico.
    </p>
  </section>

  <section class="silos" aria-label="Modelos com diagnóstico">
    {lista.map((m) => (
      <a class="silo-card" href={`/problemas/${m.slug}/`}>
        <h2>{m.marca} {m.modelo}</h2>
        <p>{m.count} {m.count === 1 ? 'diagnóstico' : 'diagnósticos'} disponíveis</p>
      </a>
    ))}
  </section>
  <SiloCta />
</BaseLayout>

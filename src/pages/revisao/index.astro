---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiloCta from '../../components/ui/SiloCta.astro';
const itens = (await getCollection('revisao', ({ data }) => !data.draft)).map((e) => ({ id: e.id, ...e.data }));

const site = 'https://hachiroku.com.br';
const url = `${site}/revisao/`;
const jsonld = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'BreadcrumbList', '@id': `${url}#breadcrumb`, itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Início', item: `${site}/` },
      { '@type': 'ListItem', position: 2, name: 'Revisão', item: url },
    ] },
    { '@type': 'CollectionPage', '@id': `${url}#webpage`,
      name: 'Tabelas de Revisão por Modelo | Hachiroku',
      description: 'Tabelas completas de revisão por quilometragem para os principais carros vendidos no Brasil. Saiba o que trocar e quando, com custos estimados.',
      inLanguage: 'pt-BR', isPartOf: { '@id': `${site}/#website` },
      publisher: { '@id': `${site}/#organization` }, breadcrumb: { '@id': `${url}#breadcrumb` } },
  ],
};
---
<BaseLayout title="Tabelas de Revisão por Modelo | Hachiroku" description="Tabelas completas de revisão por quilometragem para os principais carros vendidos no Brasil. Saiba o que trocar e quando, com custos estimados." canonical={url}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />
  <section class="hero" style="padding-block:var(--space-16)">
    <p class="kicker" style="color:var(--asphalt-300)">POR QUILOMETRAGEM · TABELAS COMPLETAS</p>
    <h1>Revisão</h1>
    <p class="tagline">O que trocar e quando</p>
  </section>
  <section class="page-intro" aria-label="Introdução">
    <p>
      A revisão preventiva é a maneira mais eficiente de evitar reparos caros e imprevistos nas estradas. Cada
      modelo tem um intervalo específico determinado pela fabricante, com itens diferentes a trocar em cada
      quilometragem. Nestas tabelas você encontra o que verificar, o que substituir e uma estimativa de custo
      para cada etapa, baseada nas especificações originais de cada veículo. Selecione o seu modelo e veja o
      plano de revisão completo, da primeira revisão até os 100 mil quilômetros.
    </p>
  </section>

  <section class="silos" aria-label="Tabelas de revisão disponíveis">
    {itens.map((i) => (<a class="silo-card" href={`/revisao/${i.id}/`}><h2>{i.title}</h2><p>{i.marca} {i.modelo}{i.custoEstimado ? ` · R$ ${i.custoEstimado}` : ''}</p></a>))}
  </section>
  <SiloCta />
</BaseLayout>

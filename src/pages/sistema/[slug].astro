---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/ui/Badge.astro';
import { SISTEMAS, getSistema, sistemaDoDefeito } from '../../lib/sistemas';

export async function getStaticPaths() {
  return SISTEMAS.map((s) => ({ params: { slug: s.slug }, props: { sistema: s } }));
}
const { sistema } = Astro.props;
const site = 'https://hachiroku.com.br';
const url = `${site}/sistema/${sistema.slug}/`;

const todos = await getCollection('problemas', ({ data }) => !data.draft);
const doSistema = todos.filter((p) => sistemaDoDefeito(p.data.defeito ?? '', p.id) ?.slug === sistema.slug);

// agrupa por modelo
const porModelo = new Map();
for (const p of doSistema) {
  const mm = p.id.split('/').slice(0, 2).join('/');
  if (!porModelo.has(mm)) porModelo.set(mm, { nome: `${p.data.entidade.marca} ${p.data.entidade.modelo}`, mm, itens: [] });
  porModelo.get(mm).itens.push(p);
}
const grupos = [...porModelo.values()].sort((a, b) => a.nome.localeCompare(b.nome));

const jsonld = { '@context': 'https://schema.org', '@graph': [
  { '@type': 'BreadcrumbList', '@id': `${url}#breadcrumb`, itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Início', item: `${site}/` },
    { '@type': 'ListItem', position: 2, name: 'Problemas', item: `${site}/problemas/` },
    { '@type': 'ListItem', position: 3, name: sistema.nome } ] },
  { '@type': 'CollectionPage', '@id': `${url}#webpage`, name: sistema.titulo, description: sistema.resumo,
    inLanguage: 'pt-BR', isPartOf: { '@id': `${site}/#website` }, breadcrumb: { '@id': `${url}#breadcrumb` },
    image: { '@type': 'ImageObject', url: `${site}/img/capas/problemas.webp`, width: 1200, height: 640 },
    publisher: { '@id': `${site}/#organization` } },
  { '@type': 'ItemList', itemListElement: doSistema.map((d, i) => ({
    '@type': 'ListItem', position: i + 1, url: `${site}/problemas/${d.id}/`, name: d.data.title })) },
] };
---
<BaseLayout title={`${sistema.seoTitle ?? sistema.titulo} | Hachiroku`} description={sistema.resumo} canonical={url} type="website">
  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />
  <article class="prose">
    <nav class="breadcrumb" aria-label="Você está em"><a href="/">Início</a> · <a href="/problemas/">Problemas</a> · <span>{sistema.nome}</span></nav>
    <header><p class="kicker">SISTEMA</p><h1 class="article-title">{sistema.titulo}</h1></header>
    <p class="lead">{sistema.resumo}</p>
    <p style="color:var(--text-muted);font-size:var(--text-sm)">{doSistema.length} diagnóstico(s) em {grupos.length} modelo(s).</p>
    <div class="defeito-grid">
      {grupos.map((g) => (
        <article class="defeito-card">
          <Badge tone="danger">{g.itens.length}</Badge>
          <h2><a href={`/problemas/${g.mm}/`}>{g.nome}</a></h2>
          <ul class="entidade-defeitos">
            {g.itens.map((p) => <li><a href={`/problemas/${p.id}/`}>{p.data.defeito ?? p.data.title}</a></li>)}
          </ul>
        </article>
      ))}
    </div>
    <nav class="modelo-xlinks" aria-label="Explore mais">
      <a href="/problemas/">Ver todos os diagnósticos →</a>
      <a href="/sistema/">Outros sistemas →</a>
    </nav>
  </article>
</BaseLayout>

---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const items = await getCollection('tecnico', ({ data }) => !data.draft);
  return items.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, seoTitle, description, kicker, autor, pubDate, updatedDate, faq, relacionados } = entry.data;

const site = 'https://hachiroku.com.br';
const url  = `${site}/tecnico/${entry.id}/`;

const jsonld: Record<string, unknown>[] = [
  {
    '@type': 'BreadcrumbList',
    '@id': `${url}#breadcrumb`,
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Início',  item: `${site}/` },
      { '@type': 'ListItem', position: 2, name: 'Técnico', item: `${site}/tecnico/` },
      { '@type': 'ListItem', position: 3, name: title, item: url },
    ],
  },
  {
    '@type': 'TechArticle',
    '@id': `${url}#article`,
    headline: title,
    description,
    inLanguage: 'pt-BR',
    url,
    datePublished: pubDate.toISOString(),
    dateModified: (updatedDate ?? pubDate).toISOString(),
    author: {
      '@type': 'Person',
      name: autor.nome,
      ...(autor.credencial && { jobTitle: autor.credencial }),
      ...(autor.sameAs     && { sameAs: autor.sameAs }),
    },
    publisher: { '@id': `${site}/#organization` },
    isPartOf: { '@id': `${site}/#website` },
    breadcrumb: { '@id': `${url}#breadcrumb` },
  },
];

if (faq.length > 0) {
  jsonld.push({
    '@type': 'FAQPage',
    '@id': `${url}#faq`,
    mainEntity: faq.map((f) => ({
      '@type': 'Question',
      name: f.pergunta,
      acceptedAnswer: { '@type': 'Answer', text: f.resposta },
    })),
  });
}
---
<BaseLayout title={seoTitle ?? title} {description} canonical={url} type="article" pubDate={pubDate} updatedDate={updatedDate} author={autor.nome}>
  <script type="application/ld+json" set:html={JSON.stringify({ '@context': 'https://schema.org', '@graph': jsonld })} />
  <article class="prose">
    <nav class="breadcrumb" aria-label="Você está em">
      <a href="/">Início</a> · <a href="/tecnico/">Técnico</a> · <span>{title}</span>
    </nav>
    <header>
      <p class="kicker">{kicker}</p>
      <h1 class="article-title">{title}</h1>
      <p class="lead"><strong>{description}</strong></p>
    </header>
    <Content />
    {faq.length > 0 && (
      <section aria-label="Perguntas frequentes">
        <h2>Perguntas frequentes</h2>
        {faq.map((f) => (
          <div class="faq-item">
            <h3>{f.pergunta}</h3>
            <p>{f.resposta}</p>
          </div>
        ))}
      </section>
    )}
    {relacionados.length > 0 && (
      <nav aria-label="Leia também">
        <h2>Leia também</h2>
        <ul>
          {relacionados.map((r) => <li><a href={r.url}>{r.titulo}</a></li>)}
        </ul>
      </nav>
    )}
  </article>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiloCta from '../../components/ui/SiloCta.astro';
const itens = (await getCollection('tecnico', ({ data }) => !data.draft)).map((e) => ({ id: e.id, ...e.data }));

const site = 'https://hachiroku.com.br';
const url = `${site}/tecnico/`;
const jsonld = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'BreadcrumbList', '@id': `${url}#breadcrumb`, itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Início', item: `${site}/` },
      { '@type': 'ListItem', position: 2, name: 'Técnico', item: url },
    ] },
    { '@type': 'CollectionPage', '@id': `${url}#webpage`,
      name: 'Como Funciona | Técnico | Hachiroku',
      description: 'Entenda como funcionam os principais sistemas do seu carro: motor, câmbio, freios, suspensão e muito mais. Explicações técnicas em linguagem acessível.',
      inLanguage: 'pt-BR', isPartOf: { '@id': `${site}/#website` },
      publisher: { '@id': `${site}/#organization` }, breadcrumb: { '@id': `${url}#breadcrumb` } },
  ],
};
---
<BaseLayout title="Como Funciona | Técnico | Hachiroku" description="Entenda como funcionam os principais sistemas do seu carro: motor, câmbio, freios, suspensão e muito mais. Explicações técnicas em linguagem acessível." canonical={url}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />
  <section class="hero" style="padding-block:var(--space-16)">
    <p class="kicker" style="color:var(--asphalt-300)">COMO FUNCIONA · GUIAS TÉCNICOS</p>
    <h1>Técnico</h1>
    <p class="tagline">Entenda seu carro por dentro</p>
  </section>
  <section class="silos" aria-label="Guias técnicos disponíveis">
    {itens.map((i) => (<a class="silo-card" href={`/tecnico/${i.id}/`}><h2>{i.title}</h2><p>{i.description}</p></a>))}
  </section>
  <SiloCta />
</BaseLayout>

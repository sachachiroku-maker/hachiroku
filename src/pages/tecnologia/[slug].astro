---
import { tecnologias } from '../../lib/entidades';
import EntidadeHub from '../../components/EntidadeHub.astro';
export function getStaticPaths() {
  return tecnologias().map((e) => ({ params: { slug: e.slug }, props: { entidade: e } }));
}
const { entidade } = Astro.props;
---
<EntidadeHub entidade={entidade} />

    { "source": "/reparos/junta-cabecote-sintomas-custo", "destination": "/manutencao/superaquecimento-motor-sinais/", "permanent": true },

    { "source": "/problemas/chevrolet/cruze/cambio-automatico-6-solavanco", "destination": "/problemas/chevrolet/cruze/cambio-automatico-trancos/", "permanent": true },
    { "source": "/problemas/chevrolet/cruze/motor-1-4-turbo-consumo-oleo", "destination": "/problemas/chevrolet/cruze/consumo-oleo-1-4-turbo/", "permanent": true },
    { "source": "/problemas/honda/hrv", "destination": "/problemas/honda/hr-v/cambio-cvt-solavanco/", "permanent": true },
    { "source": "/problemas/honda/civic/consumo-oleo-1-5t", "destination": "/problemas/honda/civic/consumo-de-oleo-turbo/", "permanent": true },
    { "source": "/problemas/nissan/kicks/cambio-cvt-xtronic", "destination": "/problemas/nissan/kicks/cambio-cvt/", "permanent": true },
    { "source": "/problemas/volkswagen/tiguan-allspace", "destination": "/problemas/volkswagen/tiguan/cambio-dsg-solavanco/", "permanent": true },
    { "source": "/problemas/jeep-compass-cambio-9-marchas", "destination": "/problemas/jeep/compass/cambio-9-marchas/", "permanent": true },
    { "source": "/problemas/byd/dolphin/autonomia-real", "destination": "/problemas/byd/dolphin/autonomia-real-abaixo-estimada/", "permanent": true },
    { "source": "/problemas/mitsubishi/l200-triton-sport", "destination": "/problemas/mitsubishi/l200-triton/corrente-timing-4n15/", "permanent": true },

    { "source": "/mecanica/cambio/cvt-como-funciona", "destination": "/tecnico/cambio-cvt-como-funciona/", "permanent": true },
    { "source": "/mecanica/motores/1-0-tsi-ea211-problemas", "destination": "/problemas/volkswagen/polo-tsi/consumo-alto-combustivel/", "permanent": true },
    { "source": "/modelos/toyota/corolla", "destination": "/ficha-tecnica/toyota/corolla/", "permanent": true },
    { "source": "/modelos/honda/civic", "destination": "/ficha-tecnica/honda/civic-touring-1-5-turbo/", "permanent": true },
    { "source": "/motor/chevrolet/css-prime-1-2-turbo", "destination": "/tecnico/motor-1-0-turbo-durabilidade/", "permanent": true },
    { "source": "/chevrolet/onix/como-funciona-turbo", "destination": "/tecnico/turbocompressor-falha-vida-util/", "permanent": true },
    { "source": "/chevrolet/onix/intervalo-revisao", "destination": "/manutencao/revisao-preventiva-10000km/", "permanent": true },

    { "source": "/guias/:path*",     "destination": "/guia-de-compra/:path*", "permanent": true },
    { "source": "/fichas/:path*",    "destination": "/ficha-tecnica/:path*",  "permanent": true },
    { "source": "/guia/:path*",      "destination": "/guia-de-compra/:path*", "permanent": true },
    { "source": "/motores/:path*",   "destination": "/motor/:path*",          "permanent": true },
    { "source": "/modelos/:path*",   "destination": "/marca/",                "permanent": true },
    { "source": "/mecanica/:path*",  "destination": "/problemas/:path*",      "permanent": false },
    { "source": "/diagnostico/:path*", "destination": "/manutencao/:path*",   "permanent": false }
  ],
  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/logos/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/pagefind/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}

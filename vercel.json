    { "source": "/ficha-tecnica/fluidos-e-lubrificantes", "destination": "/manutencao/melhor-oleo-motor-flex/", "permanent": true },

    { "source": "/eletricos/hyundai/ioniq-5", "destination": "/eletricos/hyundai-ioniq-5/", "permanent": true },

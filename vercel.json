    { "source": "/manutencao/liquido-arrefecimento-qual-usar", "destination": "/manutencao/como-verificar-fluido-arrefecimento/", "permanent": true },

    { "source": "/freios/pastilhas-de-freio-quando-trocar", "destination": "/manutencao/sinais-pastilha-freio-desgastada/", "permanent": true },
    { "source": "/freios/revisao-freios-sinais-desgaste", "destination": "/manutencao/revisao-freios-completa/", "permanent": true },
    { "source": "/freios/freio-abs-o-que-e", "destination": "/tecnico/cambio-cvt-como-funciona/", "permanent": false },
    { "source": "/eletrica/bateria-fraca-sintomas", "destination": "/manutencao/como-verificar-bateria-carro/", "permanent": true },
    { "source": "/eletrica/luz-bateria-acendeu-painel", "destination": "/manutencao/luzes-do-painel-o-que-significam/", "permanent": true },

    { "source": "/diagnostico/barulho-ao-frear", "destination": "/manutencao/barulhos-no-freio/", "permanent": true },
    { "source": "/diagnostico/luz-oleo-acendeu-painel", "destination": "/manutencao/luzes-do-painel-o-que-significam/", "permanent": true },
    { "source": "/ar-condicionado/recarga-gas-ar-condicionado-carro", "destination": "/manutencao/higienizacao-ar-condicionado-automotivo/", "permanent": true },

{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "trailingSlash": true,
  "cleanUrls": false,
  "redirects": [
    { "source": "/problemas/citro%C3%ABn/c3/:path*", "destination": "/problemas/citroen/c3/:path*", "permanent": true },
    { "source": "/problemas/citro%C3%ABn/c4/:path*", "destination": "/problemas/citroen/c4/:path*", "permanent": true },
    { "source": "/problemas/byd/song-plus-ev/:path*",             "destination": "/problemas/byd/song-plus/:path*",          "permanent": true },
    { "source": "/problemas/mitsubishi/l200-triton-sport/:path*", "destination": "/problemas/mitsubishi/l200-triton/:path*", "permanent": true },
    { "source": "/problemas/volvo/:path*",                        "destination": "/problemas/",                              "permanent": true },
    { "source": "/problemas/honda/hrv/:path*",                    "destination": "/problemas/honda/hr-v/:path*",              "permanent": true },
    { "source": "/problemas/volkswagen/tiguan/:path*",            "destination": "/problemas/volkswagen/tiguan-allspace/:path*", "permanent": true },
    { "source": "/problemas/honda/civic/sistema-el%C3%A9trico-falha/:path*", "destination": "/problemas/honda/civic/sistema-eletrico-falha/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/img/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/logos/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/pagefind/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ]
}